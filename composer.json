{
    "name": "mmt/laravel-feature-scaffold",
    "description": "Artisan commands to scaffold Laravel feature structure (make:feature, make:feature-model, make:feature-job, etc.)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "MMT\\LaravelFeatureScaffold\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MMT\\LaravelFeatureScaffold\\LaravelFeatureScaffoldServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
